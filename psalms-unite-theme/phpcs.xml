<?xml version="1.0"?>
<ruleset name="Psalms Unite Theme">
	<description>WordPress Coding Standards for the Psalms Unite theme.</description>

	<file>.</file>
	<exclude-pattern>*/assets/app/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg value="ps"/>

	<rule ref="WordPress">
		<!-- Tailwind utility markup is intentional; allow inline HTML classes. -->
		<exclude name="WordPress.WP.EnqueuedResources"/>
	</rule>

	<!-- The shortcode helpers return HTML already escaped by the plugin's
	     templates, so their output is safe to echo directly. -->
	<rule ref="WordPress.Security.EscapeOutput">
		<properties>
			<property name="customAutoEscapedFunctions" type="array">
				<element value="psalms_unite_shortcode"/>
				<element value="psalms_unite_shortcode_slot"/>
			</property>
		</properties>
	</rule>

	<config name="minimum_supported_wp_version" value="6.1"/>
</ruleset>
