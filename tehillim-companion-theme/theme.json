{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1152px",
			"wideSize": "1280px"
		},
		"color": {
			"palette": [
				{ "slug": "ink", "color": "oklch(0.22 0.04 270)", "name": "Ink" },
				{ "slug": "primary", "color": "oklch(0.34 0.11 268)", "name": "Indigo" },
				{ "slug": "primary-soft", "color": "oklch(0.94 0.04 268)", "name": "Indigo soft" },
				{ "slug": "gold", "color": "oklch(0.76 0.13 75)", "name": "Gold" },
				{ "slug": "accent", "color": "oklch(0.93 0.03 80)", "name": "Accent" },
				{ "slug": "surface", "color": "oklch(1 0 0)", "name": "Surface" },
				{ "slug": "muted", "color": "oklch(0.5 0.03 270)", "name": "Muted" },
				{ "slug": "border", "color": "oklch(0.9 0.018 85)", "name": "Border" },
				{ "slug": "page", "color": "oklch(0.985 0.012 85)", "name": "Parchment" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Heebo\", \"Inter\", ui-sans-serif, system-ui, sans-serif",
					"slug": "body",
					"name": "Body"
				},
				{
					"fontFamily": "\"Frank Ruhl Libre\", \"Fraunces\", ui-serif, Georgia, serif",
					"slug": "display",
					"name": "Display"
				}
			],
			"fluid": true
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--page)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" }
			},
			"button": {
				"border": { "radius": "999px" },
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--page)"
				},
				"spacing": {
					"padding": { "top": "14px", "bottom": "14px", "left": "28px", "right": "28px" }
				}
			},
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } }
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
