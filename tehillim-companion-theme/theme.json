{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "980px",
			"wideSize": "1180px"
		},
		"color": {
			"palette": [
				{ "slug": "ink", "color": "#23213a", "name": "Ink" },
				{ "slug": "primary", "color": "#3a3578", "name": "Indigo" },
				{ "slug": "gold", "color": "#c39a45", "name": "Gold" },
				{ "slug": "surface", "color": "#ffffff", "name": "Surface" },
				{ "slug": "muted", "color": "#6b6880", "name": "Muted" },
				{ "slug": "page", "color": "#faf8f2", "name": "Parchment" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Heebo\", \"Inter\", ui-sans-serif, system-ui, sans-serif",
					"slug": "body",
					"name": "Body"
				},
				{
					"fontFamily": "\"Frank Ruhl Libre\", \"Fraunces\", ui-serif, Georgia, serif",
					"slug": "display",
					"name": "Display"
				}
			],
			"fluid": true
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--page)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" }
			},
			"h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } },
			"h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } },
			"h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--display)" } }
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
