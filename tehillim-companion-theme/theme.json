{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "980px",
			"wideSize": "1180px"
		},
		"color": {
			"palette": [
				{ "slug": "ink", "color": "#111111", "name": "Ink" },
				{ "slug": "primary", "color": "#1f2937", "name": "Primary" },
				{ "slug": "secondary", "color": "#1f9d55", "name": "Secondary" },
				{ "slug": "surface", "color": "#ffffff", "name": "Surface" },
				{ "slug": "muted", "color": "#595959", "name": "Muted" },
				{ "slug": "page", "color": "#f7f7f7", "name": "Page" }
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Assistant\", \"Heebo\", Arial, Helvetica, sans-serif",
					"slug": "body",
					"name": "Body"
				}
			],
			"fluid": true
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--page)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"lineHeight": "1.7"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--secondary)" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	]
}
